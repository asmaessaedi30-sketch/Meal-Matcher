# Python compiled files
__pycache__/
*.pyc
*.pyo
*.pyd

# SQLite temporary files (do NOT ignore .db itself, as it holds the schema)
*.db-journal
*.db-shm
*.db-wal

# OS files
.DS_Store
Thumbs.db
